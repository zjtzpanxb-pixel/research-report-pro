# Research Report Pro - 环境配置示例

# 复制此文件为 .env 并填入真实值

# ========== 搜索 API（可选，至少配置一个）==========

# Bing Search API
# 获取地址：https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_SEARCH_API_KEY=your_bing_api_key

# Google Custom Search API
# 获取地址：https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=your_google_api_key
GOOGLE_CSE_ID=your_google_cse_id

# ========== LLM API（推荐配置）==========

# OpenAI API（或其他兼容 API）
LLM_API_KEY=your_llm_api_key

# 如果使用其他兼容 API，可自定义 endpoint
# LLM_API_BASE=https://api.openai.com/v1

# ========== 其他配置（可选）==========

# OpenClaw 工作区路径
OPENCLAW_WORKSPACE=/Users/pxb/.openclaw/workspace

# 日志级别
LOG_LEVEL=INFO
